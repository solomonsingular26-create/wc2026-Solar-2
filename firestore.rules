rules_version = '2';

// Open read/write — this is a friendly, no-login pool, so anyone with the
// page can read and write. That's intentional. Don't store anything
// sensitive here, and share the link only with your group.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
